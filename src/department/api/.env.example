# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=True
API_WORKERS=4

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173", "http://localhost:8080"]

# Database Configuration
DATABASE_URL=postgresql://koisk_user:koisk_password@localhost:5432/koisk_db
# Alternative SQLite for development:
# DATABASE_URL=sqlite:///./koisk.db

# Payment Gateway Configuration
PAYMENT_GATEWAY_ENABLED=True
PAYMENT_GATEWAY_API_KEY=your_payment_gateway_api_key
PAYMENT_GATEWAY_URL=https://api.payment-gateway.com/v1
PAYMENT_GATEWAY_TIMEOUT=30

# Email Configuration (for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_password
SMTP_FROM=noreply@koisk.com

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/koisk_api.log

# Security
SECRET_KEY=your_secret_key_here_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Service URLs (if connecting to external services)
ELECTRICITY_SERVICE_URL=http://localhost:8001
WATER_SERVICE_URL=http://localhost:8002
GAS_SERVICE_URL=http://localhost:8003

# Mock Services (Set to True to use MockServiceManager)
USE_MOCK_SERVICES=True

# API Documentation
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json
